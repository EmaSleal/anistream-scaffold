# Supabase connection
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Shared secret for internal JWT signing between Next.js and Flask.
# Must match the value in anistream/.env.local.
INTERNAL_JWT_SECRET=change-me-internal-jwt-secret

# Shared secret for Next.js-to-Flask service auth (X-Service-Key header).
# Must match the value in anistream/.env.local.
SERVICE_SECRET=change-me-service-secret

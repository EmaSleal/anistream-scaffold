# ---------------------------------------------------------------------------
# Transcoding cache
# ---------------------------------------------------------------------------

# Filesystem path where transcoded HLS segments are stored
TRANSCODE_CACHE_DIR=/cache/videos

# Maximum total cache size before LRU eviction kicks in
TRANSCODE_MAX_CACHE_GB=20

# How long a single FFmpeg process is allowed to run before being killed
TRANSCODE_FFMPEG_TIMEOUT=3600

# ---------------------------------------------------------------------------
# Progressive HLS transcoding
# ---------------------------------------------------------------------------

# Set to 1 to enable batched progressive transcode mode.
# When enabled, transcoding starts in parallel with downloads and the
# playlist is served to the client after TRANSCODE_MIN_SEGMENTS are ready.
# Set to 0 (default) to use the standard full-transcode-then-serve path.
TRANSCODE_PROGRESSIVE=0

# Minimum number of output segments that must be ready before the playlist
# is served to the client (~6s per segment, so 4 = ~24s of buffered content).
TRANSCODE_MIN_SEGMENTS=4

# Number of source segments to download and transcode per batch.
# Larger values reduce FFmpeg invocations but increase time before the first
# batch is ready.
TRANSCODE_BATCH_SIZE=20

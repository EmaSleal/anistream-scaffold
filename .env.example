# =============================================================================
# anistream-scaffold -- Environment Variables
# Copy this file to .env and fill in real values before running docker compose.
# =============================================================================

# -- Shared across BOTH services (nextjs + flask) -----------------------------
# These MUST be identical for both services. A single root .env fed to both
# containers via env_file ensures parity.

# HS256 secret used by Next.js to mint internal JWTs and by Flask to validate them.
INTERNAL_JWT_SECRET=replace-with-a-long-random-secret

# Server-to-server shared secret sent as the X-Service-Key header
# in Auth.js -> Flask calls. Must match what Flask validates.
SERVICE_SECRET=replace-with-a-long-random-secret

# -- Next.js only -------------------------------------------------------------

# Auth.js v5 session (JWE) encryption secret.
AUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth credentials (from https://console.cloud.google.com).
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Internal URL of the Flask backend.
# When running via docker compose this is overridden to http://flask:5000.
# For local dev (outside Docker) set to http://localhost:5000.
FLASK_URL=http://localhost:5000

# Public base URL of the Next.js app.
# IMPORTANT: this value is baked into the client bundle at Next.js BUILD time
# (NEXT_PUBLIC_ prefix). It must be set to the correct public URL BEFORE
# running docker build or docker compose build. Changing it at runtime
# has no effect on client-side code.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Flask only ---------------------------------------------------------------

# Supabase project URL (found in your Supabase dashboard -> Project Settings -> API).
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role key (server-side only -- never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
